{
  // 1. 设置任务：打开项目时自动进入文件夹安装依赖
  "setupTasks": [
    {
      "name": "Install Dependencies",
      "command": "cd 01-pagination && npm install"
    }
  ],

  // 2. 运行任务：安装完后自动启动 React 服务
  "tasks": {
    "start-pagination": {
      "name": "Run Pagination Project",
      "command": "cd 01-pagination && npm start",
      "runAtStart": true,
      "preview": {
        "port": 3000,
        "strategy": "browser"
      }
    }
  }
}